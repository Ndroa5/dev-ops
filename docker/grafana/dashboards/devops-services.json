{
  "title": "DevOps Microservices Overview",
  "uid": "devops-services-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-ds"
        },
        "query": "label_values(service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate 4xx/5xx (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.5, sum by (le, application) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}} p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}} p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Logs (filter by service name via $service variable above)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-ds" },
          "expr": "{service_name=~\"$service\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
